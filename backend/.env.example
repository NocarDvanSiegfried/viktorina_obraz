# GigaChat (day 2+)
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VISION_MODEL=GigaChat-Pro
GIGACHAT_CA_BUNDLE_FILE=./certs/russian_trusted_root_ca_pem.crt

# App
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=sqlite:///./data/app.db

# E2E / CI only (mock GigaChat, no network)
# E2E_MOCK_GIGACHAT=1

# Day 21: preview length for source fragments in GET /quiz/{id}
SOURCE_FRAGMENT_PREVIEW_MAX_CHARS=200
