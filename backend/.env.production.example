# Production template — copy to server as backend/.env (never commit real .env)

GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2-Pro
GIGACHAT_VISION_MODEL=GigaChat-2-Pro
GIGACHAT_CA_BUNDLE_FILE=./certs/russian_trusted_root_ca_pem.crt

# Public UI origin for CORS (HTTPS, no trailing slash)
FRONTEND_ORIGIN=https://app.example.com

DATABASE_URL=sqlite:///./data/app.db
QUIZ_GENERATE_RATE_LIMIT_MAX_REQUESTS=20
QUIZ_GENERATE_RATE_LIMIT_WINDOW_SECONDS=60
SOURCE_FRAGMENT_PREVIEW_MAX_CHARS=200

# DO NOT set in production:
# E2E_MOCK_GIGACHAT=1
