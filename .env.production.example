#
# Server deployment template for docker-compose.prod.yml
# Copy to `.env.production` on the server and fill values.
#

# Public URLs
PUBLIC_FRONTEND_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com

# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Build/runtime
COMPOSE_PROJECT_NAME=viktorina-obraz
BACKEND_ENV_FILE=./backend/.env.production
VITE_API_URL=
