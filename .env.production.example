#
# Server deployment template for docker-compose.prod.yml
# Copy to `.env.production` on the server and fill values.
#

# Public URLs
PUBLIC_FRONTEND_URL=https://www.micro-tab.ru
PUBLIC_API_URL=https://www.micro-tab.ru/api

# Host bind + ports (use localhost for reverse-proxy setup)
FRONTEND_BIND_HOST=127.0.0.1
BACKEND_BIND_HOST=127.0.0.1
FRONTEND_PORT=8081
BACKEND_PORT=8001

# Build/runtime
COMPOSE_PROJECT_NAME=viktorina-obraz
BACKEND_ENV_FILE=./backend/.env.production
VITE_API_URL=
